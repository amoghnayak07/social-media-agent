# Backend environment variables (server-side only). Copy to `.env` and fill in.
# NEVER commit a real .env. These values are read by app/config.py at startup.

# --- Database ---
# Local Docker Postgres (note port 5433 — see README) in dev; Neon URL in prod.
# Must use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://postgres_username:postgres_password@localhost:5433/comment_agent

# --- Crown-jewel secrets (env-only; never in repo/DB/logs) ---
# ENCRYPTION_KEY: Fernet key that decrypts all user secrets. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# JWT_SECRET: signs/verifies auth JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Auth / cookies ---
# Token lifetime in minutes (short — stateless JWT can't be revoked before expiry).
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Cookie attributes. DEV defaults below work for localhost over http.
# In PROD (frontend on vercel.app, backend on onrender.com = cross-site) set:
#   COOKIE_SECURE=true and COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ---
# The single browser origin allowed to call this API (must allow credentials).
FRONTEND_ORIGIN=http://localhost:5173

# --- YouTube OAuth (Phase 3; server-side only) ---
# From a Google Cloud OAuth 2.0 Client (type: Web application). The redirect URI
# below must be added EXACTLY to the client's "Authorized redirect URIs".
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/platform/youtube/callback
